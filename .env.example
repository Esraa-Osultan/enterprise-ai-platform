# Copy this file to .env and fill in real values before deploying.

APP_NAME="Enterprise AI Knowledge & Engineering Assistant"
ENVIRONMENT=development
DEBUG=true

JWT_SECRET_KEY=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

UPLOAD_DIR=data/uploads
VECTOR_STORE_DIR=data/vector_store
USERS_DB_PATH=data/users.json

# "hash" = offline/deterministic (default, no network needed).
# "sentence-transformers" = real semantic embeddings, downloads model on first use.
EMBEDDING_BACKEND=hash
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIM=384

CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4

# Leave empty to run fully offline with extractive answers/summaries.
OPENAI_API_KEY=
LLM_MODEL_NAME=gpt-4o-mini

LOG_LEVEL=INFO
LOG_FILE=data/app.log
